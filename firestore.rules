rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in user can read any user profile (needed for members list)
    // Only the user themselves can write their own doc
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /inviteTokens/{token} {
      allow read, write: if request.auth != null;
    }

    match /homes/{homeId} {
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.members
                      || request.auth.uid == resource.data.ownerUid);

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid;

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;

      allow update: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
                           && (request.auth.uid in get(/databases/$(database)/documents/homes/$(homeId)).data.members
                               || request.auth.uid == get(/databases/$(database)/documents/homes/$(homeId)).data.ownerUid);

        match /{nested}/{nestedId} {
          allow read, write: if request.auth != null
                             && (request.auth.uid in get(/databases/$(database)/documents/homes/$(homeId)).data.members
                                 || request.auth.uid == get(/databases/$(database)/documents/homes/$(homeId)).data.ownerUid);
        }
      }
    }
  }
}
